# Admin-Passwort für /admin (bitte ändern!)
ADMIN_PASSWORD=dein-sicheres-passwort

# Supabase (für Vercel/Produktion – Schreibzugriff auf Fortschritt & Admin)
# URL: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://beoxjrswwrcsubazbojy.supabase.co
# Service Role Key – NUR serverseitig, niemals im Browser!
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# Dev-Server-Port (Standard in package.json: 3002)
PORT=3002

# Nach dem Austausch von Bildern in public/images/ hochzählen → Browser lädt neu
NEXT_PUBLIC_ASSET_VERSION=2026061020
